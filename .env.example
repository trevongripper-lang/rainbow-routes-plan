# Example environment variables for local development
# Fill with your project's values (do NOT commit real secrets).

# Client-visible (safe to include in client builds)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=public-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Server-only (never expose these in the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key-REPLACE_ME
SUPABASE_DB_URL=postgres://user:pass@db-host:5432/database

# Paddle (payments) - sandbox values for development
PADDLE_CLIENT_TOKEN=your-paddle-client-token
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_PRICE_TIER1=1000
PADDLE_PRICE_TIER2=2000
PADDLE_PRICE_TIER3=3000

# Optional integrations
MAPBOX_TOKEN=your-mapbox-token
AVIATIONSTACK_API_KEY=your-aviationstack-key
SERPSTACK_API_KEY=your-serpstack-key
LOVABLE_API_KEY=your-lovable-api-key

# Runtime
NODE_ENV=development
PORT=5173
